{% extends "tela_base_pos_login/base.html" %}

{% block styles %}
<link rel="stylesheet" href="{{ url_for('static', filename='pasta_categorias/crud/edit.css') }}">
{% endblock %}

{% block content %}
<div class="form-wrapper">
    <div class="card-custom">
        <h2 style="margin-top: 0;">✏️ Editar Categoria</h2>
        <p style="color: #a0a0a0;">Altere as informações da sua categoria</p>

        <form method="POST" action="{{ url_for('categorias.editar_categoria_salvar', id=categoria[0], tipo=tipo) }}">
            
            <div class="form-group">
                <label class="form-label">Nome da Categoria</label>
                <input type="text" name="nome" class="form-input" value="{{ categoria[1] }}" required>
            </div>

            <div class="form-group">
                <label class="form-label">Cor da Categoria</label>
                <div class="color-group">
                    <input type="color" name="cor" id="cor" class="color-input" value="{{ categoria[2] }}">
                    <div id="preview" class="color-preview" style="background-color: {{ categoria[2] }};"></div>
                </div>
            </div>

            <div class="btn-row">
                <a href="{{ url_for('categorias.listar_categorias') }}" class="btn-base btn-outline">Voltar</a>
                <button type="submit" class="btn-base btn-primary">Atualizar</button>
            </div>
        </form>
    </div>
</div>

<script>
    const cp = document.getElementById('cor');
    const prev = document.getElementById('preview');
    cp.addEventListener('input', () => prev.style.backgroundColor = cp.value);
</script>
{% endblock %}