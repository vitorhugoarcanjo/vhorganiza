{% extends "tela_base_telas_unificadas/base.html" %}

{% block styles %}
<link rel="stylesheet" href="{{ url_for('static', filename='pasta_categorias/categorias.css') }}">
{% endblock %}

{% block content %}
<div class="container-custom">
    
    <div class="card-custom">
        <div class="header-flex">
            <div>
                <h2 style="margin: 0;">🏷️ Categorias</h2>
                <p style="color: var(--text-muted); margin: 5px 0 0 0;">Gerencie suas categorias de tarefas</p>
            </div>
            <div>
                <a href="{{ url_for('tarefas.ini_tarefas') }}" class="btn-base btn-outline">Voltar</a>
                <a href="{{ url_for('categorias.insert_categorias_global') }}" class="btn-base btn-primary">Nova Categoria</a>
            </div>
        </div>
    </div>

    {% if categoria_tarefas %}
    <div class="card-custom">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Cor</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for row in categoria_tarefas %}
                <tr>
                    <td>{{ row[1] }}</td>
                    <td><div class="color-preview" style="background-color: {{ row[2] }};"></div></td>
                    <td>
                        <a href="{{ url_for('edit_cat_tar.ini_edit_cat_tar', id=row[0]) }}" class="action-link">Editar</a>
                        <a href="{{ url_for('categorias.excluir_categoria', id=row[0]) }}" class="action-link" onclick="return confirm('Excluir?')">Excluir</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="card-custom" style="text-align: center; padding: 60px;">
        <h3>Nenhuma categoria criada</h3>
        <a href="{{ url_for('categorias.insert_categorias_global') }}" class="btn-base btn-primary">Criar Primeira</a>
    </div>
    {% endif %}

</div>
{% endblock %}