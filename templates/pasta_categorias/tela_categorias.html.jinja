{% extends "tela_base_pos_login/base.html" %}

{% block styles %}
<link rel="stylesheet" href="{{ static_v('pasta_categorias/categorias.css') }}">
{% endblock %}

{% block content %}

<div class="painel-container">

    <!-- =====================================================
         HEADER
    ====================================================== -->
    <div class="painel-topo-fixo">

        <div class="tarefas-controle-header">

            <div class="botoes-esquerda">

                <!-- TAREFAS -->
                <a href="{{ url_for('tarefas.ini_tarefas') }}"
                class="btn-nav btn-destaque">
                    ← Tarefas
                </a>

                <!-- FINANÇAS -->
                <a href="{{ url_for('financas.ini_financas') }}"
                class="btn-nav btn-destaque">
                    ← Finanças
                </a>

                <!-- NOVA CATEGORIA -->
                <a href="{{ url_for('categorias.insert_categorias_global') }}"
                   class="btn-pure btn-success-pure btn-destaque">
                    + Nova Categoria
                </a>

            </div>

        </div>

    </div>

    <!-- =====================================================
         GRID PRINCIPAL (TAREFAS / FINANÇAS)
    ====================================================== -->
    <div class="categorias-grid">

        <!-- ===================== TAREFAS ===================== -->
        <div class="categoria-box">

            <div class="box-header">
                <div class="box-title">🏷️ Categorias - Tarefas</div>

                <span class="badge-pure bg-primary">
                    {{ categoria_tarefas|length }} Categorias
                </span>
            </div>

            <div class="status-direita">

            </div>

            <table class="custom-table">

                <thead>
                    <tr>
                        <th>Nome</th>
                        <th style="width: 80px;">Cor</th>
                        <th style="width: 90px; text-align:center;">Ações</th>
                    </tr>
                </thead>

                <tbody>

                {% if categoria_tarefas %}

                    {% for row in categoria_tarefas %}
                    <tr>

                        <td class="td-titulo">
                            {{ row[1] }}
                        </td>

                        <td>
                            <span class="cor-dot"
                                  style="background: {{ row[2] }};"></span>
                        </td>

                        <td class="td-acoes">

                            <a href="{{ url_for('categorias.editar_categoria_form', id=row[0], tipo='tarefas') }}"
                            class="btn-acao edit"
                            title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <a href="{{ url_for('categorias.excluir_categoria', modulo='tarefas', id=row[0]) }}"
                               class="btn-acao delete"
                               title="Excluir"
                               onclick="return confirm('Excluir categoria?')">
                                <i class="bi bi-trash"></i>
                            </a>

                        </td>

                    </tr>
                    {% endfor %}

                {% else %}

                    <tr>
                        <td colspan="3" class="td-vazio">
                            <i class="bi bi-tags" style="font-size: 2rem; opacity: 0.5;"></i>
                            <p>Nenhuma categoria de tarefas</p>
                        </td>
                    </tr>

                {% endif %}

                </tbody>

            </table>

        </div>

        <!-- ===================== FINANÇAS ===================== -->
        <div class="categoria-box">

            <div class="box-header">
                <div class="box-title">💰 Categorias - Finanças</div>

                <span class="badge-pure bg-primary">
                    {{ categoria_financas|length }} Categorias
                </span>
            </div>

            <table class="custom-table">

                <thead>
                    <tr>
                        <th>Nome</th>
                        <th style="width: 80px;">Cor</th>
                        <th style="width: 90px; text-align:center;">Ações</th>
                    </tr>
                </thead>

                <tbody>

                {% if categoria_financas %}

                    {% for row in categoria_financas %}
                    <tr>

                        <td class="td-titulo">
                            {{ row[1] }}
                        </td>

                        <td>
                            <span class="cor-dot"
                                  style="background: {{ row[2] }};"></span>
                        </td>

                        <td class="td-acoes">

                            <a href="{{ url_for('categorias.editar_categoria_form', id=row[0], tipo='financas') }}"
                            class="btn-acao edit"
                            title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <a href="{{ url_for('categorias.excluir_categoria', modulo='financas', id=row[0]) }}"
                               class="btn-acao delete"
                               title="Excluir"
                               onclick="return confirm('Excluir categoria?')">
                                <i class="bi bi-trash"></i>
                            </a>

                        </td>

                    </tr>
                    {% endfor %}

                {% else %}

                    <tr>
                        <td colspan="3" class="td-vazio">
                            <i class="bi bi-tags" style="font-size: 2rem; opacity: 0.5;"></i>
                            <p>Nenhuma categoria de Finanças</p>
                        </td>
                    </tr>

                {% endif %}

                </tbody>

            </table>

        </div>

    </div>

</div>

{% endblock %}