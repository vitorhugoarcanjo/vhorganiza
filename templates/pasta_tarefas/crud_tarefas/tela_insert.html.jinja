{% extends "tela_base_pos_login/base.html" %}

{% block title %}Nova Tarefa{% endblock %}

{% block styles %}
<link rel="stylesheet" href="{{ static_v('pasta_tarefas/crud/pasta_insert/insert.css') }}">
{% endblock %}

{% block content %}

<div class="finance-wrapper">
    <div class="form-fin-card">

        <div class="form-fin-header">
            <h2><i class="bi bi-plus-circle"></i> Nova Tarefa</h2>
            <p>Preencha os dados abaixo para registrar a tarefa</p>
        </div>

        <div class="form-body">
            <form action="{{ url_for('insert_tarefas.ini_insert') }}" method="post" id="form-tarefa">

                <div class="form-grid">
                    <div class="form-group descricao-full">
                        <label class="label-form"><i class="bi bi-type"></i> Título</label>
                        <input type="text" name="titulo" class="form-input" value="{{ titulo if titulo else '' }}" placeholder="Título da tarefa..." required>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-group descricao-full">
                        <label class="label-form"><i class="bi bi-file-text"></i> Descrição</label>
                        <textarea name="descricao" class="form-input" rows="3" placeholder="O que deve ser feito?"></textarea>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label class="label-form"><i class="bi bi-check-circle"></i> Status</label>
                        <select name="status" class="form-select">
                            <option value="pendente">⏳ Pendente</option>
                            <option value="em andamento">⚡ Em andamento</option>
                            <option value="concluido">✅ Concluído</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="label-form"><i class="bi bi-flag"></i> Prioridade</label>
                        <select name="prioridade" class="form-select">
                            <option value="baixa">🟢 Baixa</option>
                            <option value="media">🟡 Média</option>
                            <option value="alta">🔴 Alta</option>
                        </select>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label class="label-form"><i class="bi bi-calendar-plus"></i> Início</label>
                        <input type="date" name="data_inicio" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label class="label-form"><i class="bi bi-calendar-check"></i> Prazo</label>
                        <input type="date" name="data_final" class="form-input">
                    </div>
                    <div class="form-group">
                        <label class="label-form"><i class="bi bi-tags"></i> Categoria</label>
                        <select name="categoria_id" class="form-select">
                            <option value="">⚠️ Sem categoria</option>
                            {% for cat in categorias %}
                            <option value="{{ cat[0] }}" style="background-color: {{ cat[2] }}; color: white;">{{ cat[1] }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

            </form>
        </div>

    </div>
</div>

<!-- FOOTER FIXO PADRÃO -->
<div class="footer-fixo-padrao">
    <div class="botoes-footer-padrao">
        <button type="submit" form="form-tarefa" class="btn-footer btn-footer-primary" id="btn-submit">
            <i class="bi bi-save"></i> Salvar
        </button>
        <a href="{{ url_for('tarefas.ini_tarefas') }}" class="btn-footer btn-footer-secondary">
            <i class="bi bi-x-circle"></i> Cancelar
        </a>
    </div>

    <div class="totalizador-footer-padrao">
        <div class="contador-footer">
            <i class="bi bi-info-circle"></i>
            <span>Preencha os campos acima</span>
        </div>
    </div>
</div>

<script>
    // Auto ajuste do textarea
    const textarea = document.querySelector('.form-input[rows="3"]');
    if (textarea) {
        textarea.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });
    }
</script>

{% block scripts %}
    <script src="{{ static_v('js/pasta_tarefas/pasta_insert/btn_insert.js') }}"></script>
{% endblock %}

{% endblock %}