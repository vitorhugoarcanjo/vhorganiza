{% extends "tela_base_pos_login/base.html" %}

{% block title %}Nova Tarefa{% endblock %}

{% block styles %}
<link rel="stylesheet" href="{{ url_for('static', filename='pasta_tarefas/crud/pasta_insert/insert.css') }}">
{% endblock %}

{% block content %}
<div class="container-task">
    <div class="card-task">
        <div class="card-task-header">
            <div class="header-align">
                <h2 class="title-main">
                    <i class="bi bi-plus-circle"></i> Nova Tarefa
                </h2>
                <a href="{{ url_for('tarefas.ini_tarefas') }}" class="btn-action btn-back">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
            </div>
            <p class="subtitle-main">Preencha os dados abaixo para registrar o fluxo</p>
        </div>

        <div class="card-task-body">
            <form action="{{ url_for('insert_tarefas.ini_insert') }}" method="post">
                
                <div class="form-group">
                    <label class="label-form"><i class="bi bi-type"></i> Título</label>
                    <input type="text" name="titulo" class="input-form" value="{{ titulo if titulo else '' }}" placeholder="Título da tarefa..." required>
                </div>

                <div class="form-group">
                    <label class="label-form"><i class="bi bi-file-text"></i> Descrição</label>
                    <textarea name="descricao" class="input-form textarea-form" rows="2" placeholder="O que deve ser feito?"></textarea>
                </div>

                <div class="form-row">
                    <div class="form-col">
                        <label class="label-form"><i class="bi bi-check-circle"></i> Status</label>
                        <select name="status" class="select-form">
                            <option value="pendente">⏳ Pendente</option>
                            <option value="em andamento">⚡ Em andamento</option>
                            <option value="concluido">✅ Concluído</option>
                        </select>
                    </div>
                    <div class="form-col">
                        <label class="label-form"><i class="bi bi-flag"></i> Prioridade</label>
                        <select name="prioridade" class="select-form">
                            <option value="baixa">🟢 Baixa</option>
                            <option value="media">🟡 Média</option>
                            <option value="alta">🔴 Alta</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-col">
                        <label class="label-form"><i class="bi bi-calendar-plus"></i> Início</label>
                        <input type="date" name="data_inicio" class="input-form" required>
                    </div>
                    <div class="form-col">
                        <label class="label-form"><i class="bi bi-calendar-check"></i> Prazo</label>
                        <input type="date" name="data_final" class="input-form">
                    </div>
                </div>

                <div class="form-group">
                    <label class="label-form"><i class="bi bi-tags"></i> Categoria</label>
                    <select name="categoria_id" class="select-form">
                        <option value="">⚠️ Sem categoria</option>
                        {% for cat in categorias %}
                        <option value="{{ cat[0] }}" style="background-color: {{ cat[2] }}; color: white;">{{ cat[1] }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-actions">
                    <button type="reset" class="btn-action btn-clear"><i class="bi bi-eraser"></i> Limpar</button>
                    <button type="submit" class="btn-action btn-submit"><i class="bi bi-save"></i> Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>


<script>
    const textarea = document.querySelector('.textarea-form');
    
    textarea.addEventListener('input', function() {
        // Reseta a altura para calcular corretamente
        this.style.height = '80px'; 
        // Ajusta baseado no conteúdo (scrollHeight)
        this.style.height = (this.scrollHeight) + 'px';
    });
</script>

{% endblock %}