<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INSERIR TAREFA</title>
    <!-- BOOTSTRAP CDN (1 linha!) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h2 class="mb-0">➕ Nova Tarefa</h2>
                    </div>
                    <div class="card-body p-4">
                        <form action="/insert_tarefas" method="post">
                            <!-- TÍTULO -->
                            <div class="mb-3">
                                <label class="form-label text-white">Título</label>
                                <input type="text" name="titulo" class="form-control bg-dark text-white border-secondary" 
                                    placeholder="Digite um título para a tarefa" required>
                            </div>


                            <!-- DESCRIÇÃO -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">Descrição</label>
                                <textarea class="form-control" rows="4" name="descricao" 
                                        placeholder="Digite a descrição da tarefa..."></textarea>
                            </div>

                            <div class="row">
                                <!-- STATUS -->
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Status</label>
                                    <select class="form-select" name="status">
                                        <option value="pendente">⏳ Pendente</option>
                                        <option value="em andamento">⚡ Em andamento</option>
                                        <option value="concluido">✅ Concluído</option>
                                    </select>
                                </div>

                                <!-- PRIORIDADE -->
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Prioridade</label>
                                    <select class="form-select" name="prioridade">
                                        <option value="baixa">🟢 Baixa</option>
                                        <option value="media">🟡 Média</option>
                                        <option value="alta">🔴 Alta</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row">
                                <!-- DATAS -->
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Data Início</label>
                                    <input type="date" class="form-control" name="data_inicio">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Data Final</label>
                                    <input type="date" class="form-control" name="data_final">
                                </div>
                            </div>

                            <!-- CATEGORIA (mantém seu estilo genial!) -->
                            <div class="mb-4">
                                <label class="form-label fw-bold">Categoria</label>
                                <select class="form-select" name="categoria_id">
                                    <option value="">⚠️ Sem categoria</option>
                                    {% for cat in categorias %}
                                    <option value="{{ cat[0] }}" 
                                            style="background-color: {{ cat[2] }}; color: white;">
                                        {{ cat[1] }}
                                    </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <!-- BOTÕES -->
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <button type="reset" class="btn btn-outline-secondary">Limpar</button>
                                <button type="submit" class="btn btn-success">💾 Salvar</button>
                                <a href="{{ url_for('tarefas.ini_tarefas') }}" class="btn btn-primary">← Voltar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
