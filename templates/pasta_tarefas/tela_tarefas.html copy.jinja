<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Bootstrap + Dark Mode -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='pasta_login_e_cadastre_se/global.css') }}">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- DataTables CSS e JS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>

    <title>Gestão de Tarefas</title>
    
    <style>
/* LAYOUT PRINCIPAL */
html, body { 
    height: 100vh; 
    margin: 0; 
    padding: 0; 
    overflow: hidden;
}

.app-container {
    display: flex;
    height: 100vh;
    width: 100%;
}

/* MENU LATERAL (7%) - FIXO */
.sidebar {
    width: 7%;
    min-width: 80px;
    background: #0a0a14;
    backdrop-filter: blur(10px);
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 0;
    z-index: 100;
    height: 100vh;
    overflow-y: auto;
}

.sidebar .logo {
    font-size: 1.8rem;
    margin-bottom: 40px;
    transition: transform 0.2s;
}

.sidebar .logo:hover {
    transform: scale(1.1);
}

.sidebar .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 0;
    margin: 8px 0;
    border-radius: 12px;
    transition: all 0.2s;
    cursor: pointer;
    text-decoration: none;
    width: 80%;
}

.sidebar .nav-item:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(4px);
}

.sidebar .nav-item.active {
    background: rgba(13, 110, 253, 0.3);
    border-left: 3px solid #0d6efd;
}

.sidebar .nav-icon {
    font-size: 1.5rem;
    margin-bottom: 4px;
}

.sidebar .nav-label {
    font-size: 0.6rem;
    text-align: center;
    font-weight: 500;
}

.sidebar .nav-spacer {
    flex: 1;
}

/* CONTEÚDO PRINCIPAL (93%) */
.main-content {
    flex: 1;
    overflow-y: auto;
    background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 100%);
    padding: 0;
}

/* SEU LAYOUT ORIGINAL - 3 COLUNAS VERTICAIS */
.container-fluid {
    height: 100% !important;
    display: flex !important;
    flex-direction: column !important;
    padding: 0 !important;
}

.row.g-0 {
    height: 100% !important;
    display: flex !important;
    flex-direction: column !important;
    flex-wrap: nowrap !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
}

/* COLUNAS FIXAS (AÇÕES e FILTROS) */
.col-acoes { 
    flex: 0 0 4% !important;
    max-height: 4% !important;
    width: 100% !important;
    background: #0f0f23 !important;
    position: sticky;
    top: 0;
    z-index: 10;
    overflow: hidden;
}

.col-filtros { 
    flex: 0 0 16% !important;
    max-height: 16% !important;
    width: 100% !important;
    background: #16213e !important;
    overflow-y: visible !important;
}

.col-filtros .h-100 {
    height: 100% !important;
    overflow-y: visible !important;
}

/* COLUNA DA TABELA - SÓ ESTA TEM SCROLL */
.col-tarefas { 
    flex: 1 !important;
    width: 100% !important;
    background: #0f0f23 !important;
    overflow-y: auto !important;
}

/* FILTROS */
.filtros-container {
    display: flex;
    flex-direction: row;
    gap: 4px;
    height: 100%;
    align-items: stretch;
    flex-wrap: nowrap;
    width: 100%;
}

.bloco-filtro {
    min-width: 0;
    display: flex;
    flex-direction: column;
    background: rgba(0,0,0,0.2);
    border-radius: 6px;
    padding: 3px;
    gap: 2px;
    height: 100%;
    overflow-y: auto;
}

.bloco-filtro:first-child {
    flex: 1.3;
}

.bloco-filtro:not(:first-child) {
    flex: 1;
}

.bloco-filtro:last-child {
    flex: 0.4;
    justify-content: center;
}

.bloco-titulo {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #6c757d;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 2px;
    margin-bottom: 1px;
    flex-shrink: 0;
}

.grupo-botoes-linha {
    display: flex;
    flex-direction: row;
    gap: 2px;
    flex-shrink: 0;
    width: 100%;
}

.grupo-inputs-data {
    display: flex;
    flex-direction: row;
    gap: 4px;
    width: 100%;
    flex-shrink: 0;
}

.input-label {
    font-size: 1rem;
    color: #6c757d;
    white-space: nowrap;
    width: 100%;
}

.input-wrapper {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    padding: 1px;
}

.input-data {
    flex: 1;
    font-size: 0.8rem;
    height: auto;
    background: transparent;
    border: none;
    color: white;
}

.btn-data {
    padding: 2px 2px;
    font-size: 0.7rem;
    min-width: 35px;
    width: 100%;
}

.lista-categorias {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.65rem;
    flex: 1;
    overflow-y: auto;
    min-height: 0;
}

.lista-categorias label {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    cursor: pointer;
}

.lista-categorias label span {
    color: #e0e0e0 !important;
    font-size: 0.7rem;
}

.status-select,
.prioridade-select {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    color: white;
    font-size: 0.7rem;
    padding: 4px 6px;
    cursor: pointer;
    width: 100%;
}

.col-acoes .d-flex {
    flex-direction: row !important;
    justify-content: space-around;
    align-items: center;
}

.nav-icon {
    display: inline-block !important;
    margin: 0 !important;
}

.content-wrapper {
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
}

.table-dark {
    background: transparent;
}

.table-dark thead th {
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: #e0e0e0;
}

@media (max-width: 768px) {
    .sidebar {
        width: 70px;
        min-width: 70px;
    }
    .sidebar .nav-label {
        display: none;
    }
    .col-acoes { 
        flex: 0 0 70px !important;
        max-height: 70px !important;
    }
    .col-filtros { 
        flex: 0 0 40vh !important;
        max-height: 40vh !important;
    }
    .col-tarefas { 
        flex: 1 !important;
    }
}
    </style>
</head>
<body>
    <div class="app-container">
        <!-- MENU LATERAL -->
        <div class="sidebar">
            <div class="logo">
                <i class="bi bi-grid-3x3-gap-fill text-primary fs-3"></i>
            </div>
            
            <a href="{{ url_for('pos_login.iniposlogin') }}" class="nav-item">
                <i class="bi bi-house-door nav-icon text-white"></i>
                <span class="nav-label text-white-50">Início</span>
            </a>
            
            <a href="{{ url_for('financas.inifinancas') }}" class="nav-item">
                <i class="bi bi-currency-dollar nav-icon text-success"></i>
                <span class="nav-label text-white-50">Finanças</span>
            </a>
            
            <a href="{{ url_for('tarefas.ini_tarefas') }}" class="nav-item active">
                <i class="bi bi-check2-square nav-icon text-info"></i>
                <span class="nav-label text-white-50">Tarefas</span>
            </a>
            
            <a href="{{ url_for('dashboard.inidashboard') }}" class="nav-item">
                <i class="bi bi-graph-up nav-icon text-warning"></i>
                <span class="nav-label text-white-50">Dashboard</span>
            </a>
            
            <a href="{{ url_for('config.iniconfig') }}" class="nav-item">
                <i class="bi bi-gear nav-icon text-secondary"></i>
                <span class="nav-label text-white-50">Config</span>
            </a>
            
            <div class="nav-spacer"></div>
            
            <a href="{{ url_for('login.validar_login') }}" class="nav-item">
                <i class="bi bi-box-arrow-right nav-icon text-danger"></i>
                <span class="nav-label text-white-50">Sair</span>
            </a>
        </div>
        
        <!-- CONTEÚDO PRINCIPAL -->
        <div class="main-content">
            <div class="container-fluid px-0">
                <div class="row g-0">
                    
                    <!-- BLOCO 1: AÇÕES (4% da altura) -->
                    <div class="col col-acoes">
                        <div class="d-flex h-100 px-3 align-items-center justify-content-between">
                            
                            <div class="text-center">
                                <i class="bi bi-grid-3x3-gap-fill text-primary fs-4"></i>
                            </div>

                            <div class="nav d-flex gap-2">
                                <a href="{{ url_for('dashboard.inidashboard') }}" class="nav-icon d-flex flex-column align-items-center text-white" title="Dashboard">
                                    <i class="bi bi-bar-chart fs-5"></i>
                                    <small style="font-size: 0.70rem;">Dashboard</small>
                                </a>
                                <a href="{{ url_for('financas.inifinancas') }}" class="nav-icon d-flex flex-column align-items-center text-success" title="Finanças">
                                    <i class="bi bi-currency-dollar fs-5"></i>
                                    <small style="font-size: 0.70rem;">Finanças</small>
                                </a>
                                <a href="#" class="nav-icon d-flex flex-column align-items-center text-warning" title="Config">
                                    <i class="bi bi-gear fs-5"></i>
                                    <small style="font-size: 0.70rem;">Config</small>
                                </a>
                            </div>
                            
                            <div class="d-flex align-items-center gap-2">
                                <div class="d-flex align-items-center gap-1">
                                    <i class="bi bi-person-circle text-white-50 fs-6"></i>
                                    <small class="text-white-50" style="font-size: 0.65rem;">{{ user_nome.split()[0] if user_nome else 'User' }}</small>
                                </div>
                                <a href="{{ url_for('login.validar_login') }}" class="nav-icon text-danger" title="Sair">
                                    <i class="bi bi-box-arrow-right fs-5"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- BLOCO 2: FILTROS (16% da altura) -->
                    <div class="col col-filtros">
                        <div class="h-100 p-1" style="overflow: visible;">
                            <form action="{{ url_for('tarefas.ini_tarefas') }}" method="POST" class="h-100">
                                <div class="filtros-container">
                                    
                                    <!-- BLOCO 1: DATA -->
                                    <div class="bloco-filtro">
                                        <div class="bloco-titulo">📅 DATA</div>
                                        
                                        <div class="grupo-botoes-linha">
                                            <button type="submit" name="tipo_filtro" value="ontem" class="btn btn-sm btn-outline-light btn-data">-1</button>
                                            <button type="submit" name="tipo_filtro" value="hoje" class="btn btn-sm btn-outline-success btn-data">HOJE</button>
                                            <button type="submit" name="tipo_filtro" value="amanha" class="btn btn-sm btn-outline-light btn-data">+1</button>
                                        </div>

                                        <div class="grupo-botoes-linha">
                                            <button type="submit" name="tipo_filtro" value="mes_passado" class="btn btn-sm btn-outline-light btn-data">-1m</button>
                                            <button type="submit" name="tipo_filtro" value="mes" class="btn btn-sm btn-outline-info btn-data">I/F</button>
                                            <button type="submit" name="tipo_filtro" value="mes_proximo" class="btn btn-sm btn-outline-light btn-data">+1m</button>
                                        </div>
                                        
                                        <div class="grupo-inputs-data">
                                            <div class="input-wrapper">
                                                <span class="input-label">Início:</span>
                                                <input type="date" name="data_inicio" class="form-control form-control-sm input-data" value="{{ data_inicio or '' }}">
                                            </div>
                                            <div class="input-wrapper">
                                                <span class="input-label">Fim/Mês:</span>
                                                <input type="date" name="data_fim" class="form-control form-control-sm input-data" value="{{ data_fim or '' }}">
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- BLOCO 2: CATEGORIAS -->
                                    <div class="bloco-filtro">
                                        <div class="bloco-titulo">🏷️ CATEGORIAS</div>
                                        
                                        <div class="lista-categorias">
                                            <label class="d-flex align-items-center" style="cursor: pointer;">
                                                <input type="checkbox" name="categorias" value="null" class="me-1" style="transform: scale(0.9);" {% if categorias_filtro and 'null' in categorias_filtro %}checked{% endif %}>
                                                <span>📭 SEM CATEGORIA</span>
                                            </label>

                                            {% for cat in categorias_usuario %}
                                            <label class="d-flex align-items-center" style="cursor: pointer;">
                                                <input type="checkbox" name="categorias" value="{{ cat[0] }}" class="me-1" style="accent-color: {{ cat[2] }}; transform: scale(0.9);" {% if categorias_filtro and cat[0]|string in categorias_filtro %}checked{% endif %}>
                                                <span style="color: #e0e0e0;">{{ cat[1] }}</span>
                                            </label>
                                            {% endfor %}
                                        </div>
                                    </div>

                                    <!-- BLOCO 3: STATUS -->
                                    <div class="bloco-filtro">
                                        <div class="bloco-titulo">📊 STATUS</div>
                                        
                                        <select name="status" class="status-select">
                                            <option value="" {% if status_filtro == '' %}selected{% endif %}>Todos</option>
                                            <option value="vazio" {% if status_filtro == 'vazio' %}selected{% endif %}>📋 Vazio (pendente validação)</option>
                                            <option value="pendente" {% if status_filtro == 'pendente' %}selected{% endif %}>⏰ Pendente</option>
                                            <option value="em andamento" {% if status_filtro == 'em andamento' %}selected{% endif %}>⏳ Em Andamento</option>
                                            <option value="concluido" {% if status_filtro == 'concluido' %}selected{% endif %}>✅ Concluído</option>
                                            <option value="concluido_em_andamento" {% if status_filtro == 'concluido_em_andamento' %}selected{% endif %}>🔄 Concluído + Em Andamento</option>
                                        </select>
                                    </div>

                                    <!-- BLOCO 4: PRIORIDADE -->
                                    <div class="bloco-filtro">
                                        <div class="bloco-titulo">⚡ PRIORIDADE</div>
                                        
                                        <select name="prioridade" class="prioridade-select">
                                            <option value="" {% if prioridade_filtro == '' %}selected{% endif %}>Todos</option>
                                            <option value="vazio" {% if prioridade_filtro == 'vazio' %}selected{% endif %}>📋 Vazio (pendente validação)</option>
                                            <option value="baixa" {% if prioridade_filtro == 'baixa' %}selected{% endif %}>🟢 Baixa</option>
                                            <option value="media" {% if prioridade_filtro == 'media' %}selected{% endif %}>🟡 Média</option>
                                            <option value="alta" {% if prioridade_filtro == 'alta' %}selected{% endif %}>🔴 Alta</option>
                                        </select>
                                    </div>

                                    <!-- BLOCO 5: DESCRIÇÃO -->
                                    <div class="bloco-filtro">
                                        <div class="bloco-titulo">🔍 DESCRIÇÃO</div>
                                        
                                        <input type="text" name="descricao" class="form-control form-control-sm bg-dark text-white" style="font-size: 0.7rem; padding: 3px 6px;" placeholder="buscar..." value="{{ descricao_filtro or '' }}" onkeypress="if(event.key === 'Enter'){ event.preventDefault(); this.form.querySelector('button[value=\'consultar\']').click(); }">
                                    </div>

                                    <!-- BLOCO 6: AÇÕES RÁPIDAS -->
                                    <div class="bloco-filtro">
                                        <div class="bloco-titulo">⚙️ AÇÕES</div>
                                        
                                        <div style="display: flex; flex-direction: column; gap: 4px; flex: 1; justify-content: center;">
                                            <a href="{{ url_for('tarefas.limpar_filtros') }}" class="btn btn-sm btn-outline-light w-100" style="font-size: 0.7rem; padding: 4px;">
                                                <i class="bi bi-eraser"></i> Limpar Todos
                                            </a>
                                            <button type="submit" name="tipo_filtro" value="consultar" class="btn btn-sm btn-primary w-100" style="font-size: 0.7rem; padding: 4px;">
                                                <i class="bi bi-search"></i> Consultar
                                            </button>
                                        </div>
                                    </div>
                                    
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- BLOCO 3: TAREFAS (80% da altura) - SÓ ESTA TEM SCROLL -->
                    <div class="col col-tarefas">
                        <div class="p-2">
                            
                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="{{ url_for('insert_tarefas.ini_insert') }}" class="btn btn-success btn-sm">
                                        <i class="bi bi-plus-circle"></i> Nova Tarefa
                                    </a>
                                    <a href="{{ url_for('categorias.listar_categorias') }}" class="btn btn-warning btn-sm">
                                        <i class="bi bi-tags"></i> Categorias
                                    </a>
                                </div>
                                <a href="{{ url_for('pos_login.iniposlogin') }}" class="btn btn-outline-light btn-sm">
                                    <i class="bi bi-arrow-left"></i> Voltar
                                </a>
                            </div>

                            <div class="content-wrapper rounded-4 overflow-hidden">
                                <div class="p-3 border-bottom" style="background: rgba(255,255,255,0.05);">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h5 class="fw-bold text-white mb-0">
                                            <i class="bi bi-list-task me-2"></i>Lista de Tarefas
                                        </h5>
                                        <span class="badge bg-primary fs-6">{{ tarefas|length }} tarefas</span>
                                    </div>
                                </div>
                                
                                <div class="table-responsive">
                                    <table class="table table-dark table-hover mb-0">
                                        <thead class="table-dark">
                                            <tr>
                                                <th class="border-0"><small>Seq</small></th>
                                                <th class="border-0"><small>Descrição</small></th>
                                                <th class="border-0"><small>Status</small></th>
                                                <th class="border-0"><small>Início</small></th>
                                                <th class="border-0"><small>Fim</small></th>
                                                <th class="border-0"><small>Categoria</small></th>
                                                <th class="border-0"><small>Prioridade</small></th>
                                                <th class="border-0"><small>Ações</small></th>
                                            </thead>
                                            <tbody>
                                                {% if tarefas %}
                                                    {% for tarefa in tarefas %}
                                                    <tr class="align-middle">
                                                        <td class="fw-semibold text-white-50">{{ tarefa[0] }}</td>
                                                        <td class="text-white">{{ tarefa[1] }}</td>
                                                        <td>
                                                            {% if tarefa[2] == 'concluido' %}
                                                                <span class="badge bg-success">✅ Concluída</span>
                                                            {% elif tarefa[2] == 'em andamento' %}
                                                                <span class="badge bg-warning text-dark">⏳ Andamento</span>
                                                            {% else %}
                                                                <span class="badge bg-danger">⏰ Pendente</span>
                                                            {% endif %}
                                                        </td>
                                                        <td><span class="text-white-50">{{ tarefa[3] or '-' }}</span></td>
                                                        <td><span class="text-white-50">{{ tarefa[4] or '-' }}</span></td>
                                                        <td>
                                                            {% if tarefa[7] %}
                                                                <span class="badge fw-semibold" style="background-color: {{ tarefa[8] }}; color: white;">
                                                                    {{ tarefa[7] }}
                                                                </span>
                                                            {% else %}
                                                                <span class="badge bg-secondary">-</span>
                                                            {% endif %}
                                                        </td>
                                                        <td>
                                                            {% if tarefa[6] %}
                                                                {% set prio_class = 'bg-danger' if tarefa[6] == 'alta' else 'bg-warning text-dark' if tarefa[6] == 'media' else 'bg-success' %}
                                                                <span class="badge {{ prio_class }} fw-semibold">{{ tarefa[6]|title }}</span>
                                                            {% else %}
                                                                <span class="badge bg-secondary">-</span>
                                                            {% endif %}
                                                        </td>
                                                        <td>
                                                            {% if tarefa[2] != 'concluido' %}
                                                                <div class="btn-group" role="group">
                                                                    <form method="post" action="{{ url_for('tarefas.concluir_tarefa', tarefa_seq=tarefa[0]) }}" style="display:inline;">
                                                                        <button class="btn btn-success btn-sm" title="Concluir">
                                                                            <i class="bi bi-check-lg"></i>
                                                                        </button>
                                                                    </form>
                                                                    <a href="{{ url_for('editar_tarefa.iniedittarefa', tarefa_seq=tarefa[0]) }}" class="btn btn-primary btn-sm" title="Editar">
                                                                        <i class="bi bi-pencil"></i>
                                                                    </a>
                                                                    <form method="post" action="{{ url_for('tarefas.excluir_tarefa', tarefa_seq=tarefa[0]) }}" style="display:inline;" onsubmit="return confirm('Confirmar exclusão?')">
                                                                        <button class="btn btn-danger btn-sm" title="Excluir">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    </form>
                                                                </div>
                                                            {% else %}
                                                                <span class="badge bg-success fs-6">✅ Finalizada</span>
                                                            {% endif %}
                                                        </td>
                                                    </tr>
                                                    {% endfor %}
                                                {% else %}
                                                    <tr>
                                                        <td colspan="8" class="text-center py-5">
                                                            <div class="text-center text-white-50 py-5">
                                                                <i class="bi bi-calendar-check display-1 mb-4 opacity-50"></i>
                                                                <h4 class="fw-bold mb-3">Nenhuma tarefa cadastrada ou nesse período</h4>
                                                                <p class="lead mb-4">Comece criando sua primeira tarefa</p>
                                                                <a href="{{ url_for('insert_tarefas.ini_insert') }}" class="btn btn-success btn-lg px-5">
                                                                    <i class="bi bi-plus-circle me-2"></i>Nova Tarefa
                                                                </a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                {% endif %}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    function desmarcarTodosOff() {
        document.querySelectorAll('#offcanvasCategorias input[name="categorias"]').forEach(cb => cb.checked = false);
    }
    </script>
</body>
