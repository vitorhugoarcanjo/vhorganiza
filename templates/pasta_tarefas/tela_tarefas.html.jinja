{% extends "tela_base_telas_unificadas/base.html" %}

{% block title %}Gestão de Tarefas{% endblock %}

{% block extra_css %}
<style>
/* ============================================ */
/* TODO O CSS ESPECÍFICO DA TELA DE TAREFAS     */
/* ============================================ */






/* Remove o padding do main-content apenas nesta página pois na base tem um valor diferente */
.main-content {
    padding: 5px !important;
}

/* SEU LAYOUT ORIGINAL - 2 COLUNAS VERTICAIS */
.container-fluid {
    height: 100% !important;
    display: flex !important;
    flex-direction: column !important;
    padding: 0 !important;
}

.row.g-0 {
    height: 100% !important;
    display: flex !important;
    flex-direction: column !important;
    flex-wrap: nowrap !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
}

/* COLUNAS FIXAS (FILTROS) */
.col-filtros { 
    flex: 0 0 16% !important;
    max-height: 16% !important;
    width: 100% !important;
    background: #16213e !important;
    overflow-y: visible !important;
    border-radius: 5px;
}

.col-filtros .h-100 {
    height: 100% !important;
    overflow-y: visible !important;
}

/* COLUNA DA TABELA - SÓ ESTA TEM SCROLL */
.col-tarefas { 
    flex: 1 !important;
    width: 100% !important;
    background: #0f0f23 !important;
    overflow-y: auto !important;
}

/* FILTROS */
.filtros-container {
    display: flex;
    flex-direction: row;
    gap: 4px;
    height: 100%;
    align-items: stretch;
    flex-wrap: nowrap;
    width: 100%;
}

.bloco-filtro {
    min-width: 0;
    display: flex;
    flex-direction: column;
    background: rgba(0,0,0,0.2);
    border-radius: 6px;
    padding: 3px;
    gap: 2px;
    height: 100%;
    overflow-y: auto;
}

.bloco-filtro:first-child {
    flex: 1.3;
}

.bloco-filtro:not(:first-child) {
    flex: 1;
}

.bloco-filtro:last-child {
    flex: 0.4;
    justify-content: center;
}

.bloco-titulo {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #ffffff;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 2px;
    margin-bottom: 1px;
    flex-shrink: 0;
}

.grupo-botoes-linha {
    display: flex;
    flex-direction: row;
    gap: 2px;
    flex-shrink: 0;
    width: 100%;
}

.grupo-inputs-data {
    display: flex;
    flex-direction: row;
    gap: 4px;
    width: 100%;
    flex-shrink: 0;
}

.input-label {
    font-size: 1rem;
    color: #6c757d;
    white-space: nowrap;
    width: 100%;
}

.input-wrapper {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
}

.input-data {
    flex: 1;
    font-size: 0.8rem;
    height: auto;
    background: transparent;
    border: none;
    color: white;
}

.btn-data {
    padding: 2px 2px;
    font-size: 0.7rem;
    min-width: 35px;
    width: 100%;
}

.lista-categorias {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.65rem;
    flex: 1;
    overflow-y: auto;
    min-height: 0;
}

.lista-categorias label {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    cursor: pointer;
}

.lista-categorias label .span_categorias {
    color: #e0e0e0;
    font-size: 0.7rem;
}

.status-select,
.prioridade-select {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    color: white;
    font-size: 0.7rem;
    padding: 4px 6px;
    cursor: pointer;
    width: 100%;
}

.nav-icon {
    display: inline-block !important;
    margin: 0 !important;
}

.content-wrapper {
    background: rgba(239, 236, 236, 0.2);
    border-radius: 12px;
}

/* TAREFAS */
.btn-edit-tar {
    border-radius: 12px !important;
}


/* ============================================ */
/* 1. CONFIGURAÇÕES GERAIS DA TABELA           */
/* ============================================ */

.custom-table {
    width: 100%;
    margin-bottom: 0;
}



/* ============================================ */
/* 2. TEMA ESCURO (PADRÃO) - TABELA            */
/* ============================================ */
.container_list_taf {
    background: rgba(255, 255, 255, 0.05);
}

.custom-table thead th {
    color: #e0e0e0;
    background: transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    font-weight: 600;
    padding: 12px 8px;
}

.custom-table tbody td {
    color: #e0e0e0;
    background: transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 10px 8px;
    vertical-align: middle;
}

.custom-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.05);
}



/* ============================================ */
/* 3. TEMA CLARO - TABELA                      */
/* ============================================ */
/* Sobrescreve o fundo do main-content no tema claro */
body.light-mode .main-content {
    background-color: #bbcdd1 !important;
    background-image: none !important; /* remove o gradiente do tema escuro */
}

body.light-mode .col-tarefas {
    background-color: transparent !important;
}


body.light-mode .custom-table {
    background: #ffffff;
}

body.light-mode .custom-table thead th {
    color: #212529 !important;
    background: #f8f9fa !important;
    border-bottom-color: #dee2e6 !important;
}

body.light-mode .custom-table tbody td {
    color: #212529 !important;
    border-bottom-color: #e9ecef !important;
}

body.light-mode .custom-table tbody tr:hover {
    background: #f5f5f5 !important;
}

/* CONTAINER FILTRO E GERAL */
body.light-mode .col-filtros {
    background-color: #1c589c !important;
}
body.light-mode .bloco-filtro {
    background-color: #dbe3e8;
}

body.light-mode .bloco-titulo {
    color: #0f0f23;
    font-size: 0.8rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.497);
}

/* BLOCO DATA */
body.light-mode .input-data, body.light-mode .btn-data {
    color: #0f0f23;
}

body.light-mode .input-wrapper {
    color: #0f0f23;
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.2);
}

/* BLOCO CATEGORIAS */
body.light-mode .label-categoria {
    color: #0f0f23;
}
body.light-mode .span_categorias {
    color: #000000;
    font-size: 0.7rem;
}

/* BLOCO STATUS E PRIORIDADE */
body.light-mode .status-select,
body.light-mode .prioridade-select {
    background: rgb(249, 249, 249);
    border: 1px solid rgba(255,255,255,0.2);
    color: rgb(0, 0, 0);

}

/* BLOCO ACOES */
body.light-mode .btn-outline-light {
    border-color: #252729;
    color: #232628;
}

/* BLOCO TAREFAS */
body.light-mode .text-white {
    color: #212529 !important;
}

body.light-mode .text-white-50 {
    color: #000000 !important;
}

body.light-mode .badge.bg-secondary {
    background-color: #cdcdcd !important;
    color: white;
}
body.light-mode .container_list_taf{
    background-color: #cdcdcd !important;
}



@media (max-width: 768px) {
    .col-filtros { 
        flex: 0 0 40vh !important;
        max-height: 40vh !important;
    }
    .col-tarefas { 
        flex: 1 !important;
    }
}
</style>
{% endblock %}

{% block content %}
<!-- ============================================ -->
<!-- SEU CONTEÚDO COMPLETO (SEM O MENU LATERAL)   -->
<!-- ============================================ -->
<div class="container-fluid px-0">
    <div class="row g-0">

        <!-- BLOCO 2: FILTROS (16% da altura) -->
        <div class="col col-filtros">
            <div class="h-100 p-1" style="overflow: visible;">
                <form action="{{ url_for('tarefas.ini_tarefas') }}" method="POST" class="h-100">
                    <div class="filtros-container">
                        
                        <!-- BLOCO 1: DATA -->
                        <div class="bloco-filtro">
                            <div class="bloco-titulo">📅 DATA</div>
                            
                            <div class="grupo-botoes-linha">
                                <button type="submit" name="tipo_filtro" value="ontem" class="btn btn-sm btn-outline-light btn-data">-1</button>
                                <button type="submit" name="tipo_filtro" value="hoje" class="btn btn-sm btn-outline-success btn-data">HOJE</button>
                                <button type="submit" name="tipo_filtro" value="amanha" class="btn btn-sm btn-outline-light btn-data">+1</button>
                            </div>

                            <div class="grupo-botoes-linha">
                                <button type="submit" name="tipo_filtro" value="mes_passado" class="btn btn-sm btn-outline-light btn-data">-1m</button>
                                <button type="submit" name="tipo_filtro" value="mes" class="btn btn-sm btn-outline-info btn-data">I/F</button>
                                <button type="submit" name="tipo_filtro" value="mes_proximo" class="btn btn-sm btn-outline-light btn-data">+1m</button>
                            </div>
                            
                            <div class="grupo-inputs-data">
                                <div class="input-wrapper">
                                    <span class="input-label">Início:</span>
                                    <input type="date" name="data_inicio" class="form-control form-control-sm input-data" value="{{ data_inicio or '' }}">
                                </div>
                                <div class="input-wrapper">
                                    <span class="input-label">Fim/Mês:</span>
                                    <input type="date" name="data_fim" class="form-control form-control-sm input-data" value="{{ data_fim or '' }}">
                                </div>
                            </div>
                        </div>
                        
                        <!-- BLOCO 2: CATEGORIAS -->
                        <div class="bloco-filtro">
                            <div class="bloco-titulo">🏷️ CATEGORIAS</div>
                            
                            <div class="lista-categorias">
                                <label class="d-flex align-items-center label-categoria" style="cursor: pointer;">
                                    <input type="checkbox" name="categorias" value="null" class="me-1" style="transform: scale(0.9);" {% if categorias_filtro and 'null' in categorias_filtro %}checked{% endif %}>
                                    <span class="span_categorias">📭 SEM CATEGORIA</span>
                                </label>

                                {% for cat in categorias_usuario %}
                                <label class="d-flex align-items-center label-categoria" style="cursor: pointer;">
                                    <input type="checkbox" name="categorias" value="{{ cat[0] }}" class="me-1" style="accent-color: {{ cat[2] }}; transform: scale(0.9);" {% if categorias_filtro and cat[0]|string in categorias_filtro %}checked{% endif %}>
                                    <span class="span_categorias">{{ cat[1] }}</span>
                                </label>
                                {% endfor %}
                            </div>
                        </div>

                        <!-- BLOCO 3: STATUS -->
                        <div class="bloco-filtro">
                            <div class="bloco-titulo">📊 STATUS</div>
                            
                            <select name="status" class="status-select">
                                <option value="" {% if status_filtro == '' %}selected{% endif %}>Todos</option>
                                <option value="vazio" {% if status_filtro == 'vazio' %}selected{% endif %}>📋 Vazio (pendente validação)</option>
                                <option value="pendente" {% if status_filtro == 'pendente' %}selected{% endif %}>⏰ Pendente</option>
                                <option value="em andamento" {% if status_filtro == 'em andamento' %}selected{% endif %}>⏳ Em Andamento</option>
                                <option value="concluido" {% if status_filtro == 'concluido' %}selected{% endif %}>✅ Concluído</option>
                                <option value="concluido_em_andamento" {% if status_filtro == 'concluido_em_andamento' %}selected{% endif %}>🔄 Concluído + Em Andamento</option>
                            </select>
                        </div>

                        <!-- BLOCO 4: PRIORIDADE -->
                        <div class="bloco-filtro">
                            <div class="bloco-titulo">⚡ PRIORIDADE</div>
                            
                            <select name="prioridade" class="prioridade-select">
                                <option value="" {% if prioridade_filtro == '' %}selected{% endif %}>Todos</option>
                                <option value="vazio" {% if prioridade_filtro == 'vazio' %}selected{% endif %}>📋 Vazio (pendente validação)</option>
                                <option value="baixa" {% if prioridade_filtro == 'baixa' %}selected{% endif %}>🟢 Baixa</option>
                                <option value="media" {% if prioridade_filtro == 'media' %}selected{% endif %}>🟡 Média</option>
                                <option value="alta" {% if prioridade_filtro == 'alta' %}selected{% endif %}>🔴 Alta</option>
                            </select>
                        </div>

                        <!-- BLOCO 5: DESCRIÇÃO -->
                        <div class="bloco-filtro">
                            <div class="bloco-titulo">🔍 DESCRIÇÃO</div>
                            
                            <input type="text" name="descricao" class="form-control form-control-sm text-black" style="font-size: 0.7rem; padding: 3px 6px;" placeholder="buscar..." value="{{ descricao_filtro or '' }}" onkeypress="if(event.key === 'Enter'){ event.preventDefault(); this.form.querySelector('button[value=\'consultar\']').click(); }">
                        </div>

                        <!-- BLOCO 6: AÇÕES RÁPIDAS -->
                        <div class="bloco-filtro">
                            <div class="bloco-titulo">⚙️ AÇÕES</div>
                            
                            <div style="display: flex; flex-direction: column; gap: 4px; flex: 1; justify-content: center;">
                                <a href="{{ url_for('tarefas.limpar_filtros') }}" class="btn btn-sm btn-outline-light w-100" style="font-size: 0.8rem; padding: 4px;">
                                    <i class="bi bi-eraser"></i> Limpar Todos
                                </a>
                                <button type="submit" name="tipo_filtro" value="consultar" class="btn btn-sm btn-primary w-100" style="font-size: 0.8rem; padding: 4px;">
                                    <i class="bi bi-search"></i> Consultar
                                </button>
                            </div>
                        </div>
                        
                    </div>
                </form>
            </div>
        </div>

        <!-- BLOCO 3: TAREFAS (80% da altura) - SÓ ESTA TEM SCROLL -->
        <div class="col col-tarefas">
            <div class="p-1">
                
                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="{{ url_for('insert_tarefas.ini_insert') }}" class="btn btn-success btn-sm">
                            <i class="bi bi-plus-circle"></i> Nova Tarefa
                        </a>
                        <a href="{{ url_for('categorias.listar_categorias') }}" class="btn btn-warning btn-sm">
                            <i class="bi bi-tags"></i> Categorias
                        </a>
                    </div>
                </div>

                <div class="content-wrapper rounded-4 overflow-hidden">
                    <div class="p-2 border-bottom container_list_taf">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold text-white mb-0">
                                <i class="bi bi-list-task me-2"></i>Lista de Tarefas
                            </h5>
                            <span class="badge bg-primary fs-6">{{ tarefas|length }} tarefas</span>
                        </div>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 custom-table">
                            <thead>
                                <tr>
                                    <th class="border-0"><small>Nº_REG.</small></th>
                                    <th class="border-0"><small>DESCRIÇÃO</small></th>
                                    <th class="border-0"><small>STATUS</small></th>
                                    <th class="border-0"><small>DATA_INICIO</small></th>
                                    <th class="border-0"><small>DATA_FINAL</small></th>
                                    <th class="border-0"><small>CATEGORIA</small></th>
                                    <th class="border-0"><small>PRIORIDADE</small></th>
                                    <th class="border-0"><small>AÇÕES</small></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% if tarefas %}
                                    {% for tarefa in tarefas %}
                                    <tr class="align-middle">
                                        <td class="fw-semibold text-white-50">{{ tarefa[0] }}</td>
                                        <td class="text-white">{{ tarefa[1] }}</td>
                                        <td>
                                            {% if tarefa[2] == 'concluido' %}
                                                <span class="badge bg-success">✅ Concluída</span>
                                            {% elif tarefa[2] == 'em andamento' %}
                                                <span class="badge bg-warning text-dark">⏳ Andamento</span>
                                            {% else %}
                                                <span class="badge bg-danger">⏰ Pendente</span>
                                            {% endif %}
                                        </td>
                                        <td><span class="text-white-50">{{ tarefa[3] or '-' }}</span></td>
                                        <td><span class="text-white-50">{{ tarefa[4] or '-' }}</span></td>
                                        <td>
                                            {% if tarefa[7] %}
                                                <span class="badge fw-semibold" style="background-color: {{ tarefa[8] }}; color: white;">
                                                    {{ tarefa[7] }}
                                                </span>
                                            {% else %}
                                                <span class="badge bg-secondary">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if tarefa[6] %}
                                                {% set prio_class = 'bg-danger' if tarefa[6] == 'alta' else 'bg-warning text-dark' if tarefa[6] == 'media' else 'bg-success' %}
                                                <span class="badge {{ prio_class }} fw-semibold">{{ tarefa[6]|title }}</span>
                                            {% else %}
                                                <span class="badge bg-secondary">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if tarefa[2] != 'concluido' %}
                                                <div class="btn-group" role="group">
                                                    <form method="post" action="{{ url_for('tarefas.concluir_tarefa', tarefa_seq=tarefa[0]) }}" style="display:inline;">
                                                        <button class="btn btn-success btn-sm" title="Concluir">
                                                            <i class="bi bi-check-lg"></i>
                                                        </button>
                                                    </form>
                                                    <a href="{{ url_for('editar_tarefa.iniedittarefa', tarefa_seq=tarefa[0]) }}" class="btn btn-primary btn-sm btn-edit-tar" title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form method="post" action="{{ url_for('tarefas.excluir_tarefa', tarefa_seq=tarefa[0]) }}" style="display:inline;" onsubmit="return confirm('Confirmar exclusão?')">
                                                        <button class="btn btn-danger btn-sm" title="Excluir">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            {% else %}
                                                <span class="badge bg-success fs-8">✅</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="8" class="text-center py-5">
                                            <div class="text-center text-white-50 py-5">
                                                <i class="bi bi-calendar-check display-1 mb-4 opacity-50"></i>
                                                <h4 class="fw-bold mb-3">Nenhuma tarefa cadastrada ou nesse período</h4>
                                                <p class="lead mb-4">Comece criando sua primeira tarefa</p>
                                                <a href="{{ url_for('insert_tarefas.ini_insert') }}" class="btn btn-success btn-lg px-5">
                                                    <i class="bi bi-plus-circle me-2"></i>Nova Tarefa
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}