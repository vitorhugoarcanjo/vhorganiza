{% extends "tela_base_pos_login/base.html" %}

{% block title %}Gestão de Tarefas{% endblock %}

{% block styles %}
    <link rel="stylesheet" href="{{ static_v('pasta_tarefas/import_css.css') }}">

    <!-- CSS MODAL - CONCLUIR TAREFA -->
    <link rel="stylesheet" href="{{ static_v('pasta_tarefas/modais/concluir_tarefa.css') }}">

    <!-- CSS MODAL - DETALHES COMPLETO -->
    <link rel="stylesheet" href="{{ static_v('pasta_tarefas/modais/detalhes_completo.css') }}">

    <!-- CSS MODAL - EXCLUIR TAREFA -->
    <link rel="stylesheet" href="{{ static_v('pasta_tarefas/modais/excluir_global.css') }}">
{% endblock %}

{% block content %}
<div class="painel-container">

    <div class="painel-topo-fixo">
        <form action="{{ url_for('tarefas.ini_tarefas') }}" method="POST" class="form-filtros-total">
            <div class="filtros-container">
                
                <div class="bloco-filtro">
                    <div class="bloco-titulo">📅 DATA</div>
                    <div class="flex-row gap-1">
                        <button type="submit" name="tipo_filtro" value="ontem" class="btn-pure flex-fill">-1</button>
                        <button type="submit" name="tipo_filtro" value="hoje" class="btn-pure btn-success-pure flex-fill">HOJE</button>
                        <button type="submit" name="tipo_filtro" value="amanha" class="btn-pure flex-fill">+1</button>
                    </div>
                    <div class="flex-row gap-1" style="margin-top: 2px;">
                        <button type="submit" name="tipo_filtro" value="mes_passado" class="btn-pure flex-fill">-1m</button>
                        <button type="submit" name="tipo_filtro" value="mes" class="btn-pure btn-info-pure flex-fill">I/F</button>
                        <button type="submit" name="tipo_filtro" value="mes_proximo" class="btn-pure flex-fill">+1m</button>
                    </div>
                    <div class="flex-row gap-1" style="margin-top: 3px;">
                        <div class="flex-fill">
                            <input type="date" name="data_inicio" class="form-control" value="{{ data_inicio or '' }}" onkeypress="if(event.key === 'Enter'){ event.preventDefault(); this.form.querySelector('button[value=\'consultar\']').click(); }">
                        </div>
                        <div class="flex-fill">
                            <input type="date" name="data_fim" class="form-control" value="{{ data_fim or '' }}" onkeypress="if(event.key === 'Enter'){ event.preventDefault(); this.form.querySelector('button[value=\'consultar\']').click(); }">
                        </div>
                    </div>
                    <div style="margin-top: 3px;">
                        <select name="tipo_data" class="form-select">
                            <option value="inicio" {% if tipo_data == 'inicio' %}selected{% endif %}>📅 DATA INICIO</option>
                            <option value="final" {% if tipo_data == 'final' %}selected{% endif %}>⏰ DATA FINAL</option>
                            <option value="finalizacao" {% if tipo_data == 'finalizacao' %}selected{% endif %}>✅ DATA FINALIZAÇÃO</option>
                        </select>
                    </div>
                    <input type="hidden" name="mostrar_inativas" value="{{ mostrar_inativas }}">
                </div>
                
                <div class="bloco-filtro">
                    <div class="bloco-titulo">🏷️ CATEGORIAS</div>
                    <div class="lista-categorias scroll-fino">
                        <label class="label-categoria">
                            <input type="checkbox" name="categorias" value="null" class="me-1" {% if categorias_filtro and 'null' in categorias_filtro %}checked{% endif %}>
                            <span class="span_categorias">📭 SEM CATEGORIA</span>
                        </label>
                        {% for cat in categorias_usuario %}
                        <label class="label-categoria">
                            <input type="checkbox" name="categorias" value="{{ cat[0] }}" class="me-1" {% if categorias_filtro and cat[0]|string in categorias_filtro %}checked{% endif %}>
                            <span class="span_categorias" style="color: {{ cat[2] }}; font-weight: 500;">{{ cat[1] }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                <div class="bloco-filtro">
                    <div class="bloco-titulo">📊 OUTROS FILTROS</div>
                    
                    <div class="flex-row gap-2">
                        <div class="flex-fill">
                            <label class="text-white-50" style="font-size: var(--fs-micro); display:block; margin-bottom:1px;">Status</label>
                            <select name="status" class="form-select">
                                <option value="" {% if status_filtro == '' %}selected{% endif %}>Todos</option>
                                <option value="vazio" {% if status_filtro == 'vazio' %}selected{% endif %}>📋 Vazio</option>
                                <option value="pendente" {% if status_filtro == 'pendente' %}selected{% endif %}>⏰ Pendente</option>
                                <option value="em andamento" {% if status_filtro == 'em andamento' %}selected{% endif %}>⏳ Andamento</option>
                                <option value="concluido" {% if status_filtro == 'concluido' %}selected{% endif %}>✅ Concluído</option>
                                <option value="pendente_em_andamento" {% if status_filtro == 'pendente_em_andamento' %}selected{% endif %}>🔄 Pend+Andam</option>
                            </select>
                        </div>
                        
                        <div class="flex-fill">
                            <label class="text-white-50" style="font-size: var(--fs-micro); display:block; margin-bottom:1px;">Prioridade</label>
                            <select name="prioridade" class="form-select">
                                <option value="" {% if prioridade_filtro == '' %}selected{% endif %}>Todos</option>
                                <option value="vazio" {% if prioridade_filtro == 'vazio' %}selected{% endif %}>📋 Vazio</option>
                                <option value="baixa" {% if prioridade_filtro == 'baixa' %}selected{% endif %}>🟢 Baixa</option>
                                <option value="media" {% if prioridade_filtro == 'media' %}selected{% endif %}>🟡 Média</option>
                                <option value="alta" {% if prioridade_filtro == 'alta' %}selected{% endif %}>🔴 Alta</option>
                            </select>
                        </div>
                    </div>

                    <div style="margin-top: 4px;">
                        <label class="text-white-50" style="font-size: var(--fs-micro); display:block; margin-bottom:1px;">Tarefa:</label>
                        <div class="flex-row gap-1">
                            <a href="{{ url_for('tarefas.ini_tarefas', mostrar_inativas='0') }}" class="btn-pure flex-fill {% if mostrar_inativas == '0' %}btn-active-toggle{% endif %}">Ativas</a>
                            <a href="{{ url_for('tarefas.ini_tarefas', mostrar_inativas='1') }}" class="btn-pure flex-fill {% if mostrar_inativas == '1' %}btn-active-toggle{% endif %}">Inativas</a>
                            <a href="{{ url_for('tarefas.ini_tarefas', mostrar_inativas='2') }}" class="btn-pure flex-fill {% if mostrar_inativas == '2' %}btn-active-toggle{% endif %}">Todas</a>
                        </div>
                    </div>
                </div>

                <div class="bloco-filtro bloco-pesquisa-fim">
                    <div>
                        <div class="bloco-titulo">🔍 DESCRIÇÃO</div>
                        <input type="text" name="descricao" class="form-control" placeholder="buscar..." value="{{ descricao_filtro or '' }}" onkeypress="if(event.key === 'Enter'){ event.preventDefault(); this.form.querySelector('button[value=\'consultar\']').click(); }">
                    </div>
                    <div class="flex-row gap-1" style="margin-top: 6px;">
                        <a href="{{ url_for('tarefas.limpar_filtros') }}" class="btn-pure flex-fill" style="text-align: center;">Limpar Todos</a>
                        <button type="submit" name="tipo_filtro" value="consultar" class="btn-pure btn-primary-pure flex-fill">Consultar</button>
                    </div>
                </div>

            </div>
        </form>

        <div class="tarefas-controle-header">
            <div class="botoes-esquerda">
                <a href="{{ url_for('insert_tarefas.ini_insert') }}" class="btn-pure btn-success-pure btn-destaque">+ Nova Tarefa</a>
                <a href="{{ url_for('categorias.listar_categorias') }}" class="btn-pure btn-info-pure">Categorias</a>
            </div>
            <div class="status-direita">
                <span class="badge-pure bg-primary">{{ tarefas|length }} tarefas</span>
            </div>
        </div>
    </div>

    <div class="painel-tabela-conteudo scroll-fino">
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th style="width: 65px;">Nº REG.</th>
                        <th>TÍTULO</th>
                        <th style="width: 100px;">STATUS</th>
                        <th style="width: 95px;">DATA INICIO</th>
                        <th style="width: 95px;">DATA FINAL</th>
                        <th style="width: 115px;">DATA FINALIZAÇÃO</th>
                        <th style="width: 120px;">CATEGORIA</th>
                        <th style="width: 95px;">PRIORIDADE</th>
                        <th style="width: 145px; text-align: center;">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    {% if tarefas %}
                        {% for tarefa in tarefas %}
                        <tr>
                            <td class="td-id">{{ tarefa[0] }}</td>
                            <td class="td-titulo" title="{{ tarefa[1] }}">{{ tarefa[1] }}</td>
                            <td>
                                {% if tarefa[3] == 'concluido' %}
                                    <span class="badge-pure bg-success">✅ Concluída</span>
                                {% elif tarefa[3] == 'em andamento' %}
                                    <span class="badge-pure bg-warning text-dark">⏳ Andamento</span>
                                {% else %}
                                    <span class="badge-pure bg-danger">⏰ Pendente</span>
                                {% endif %}
                            </td>
                            <td>{{ tarefa[4] or '-' }}</td>
                            <td>{{ tarefa[5] or '-' }}</td>
                            <td>
                                {% if tarefa[6] and tarefa[6] != '-' %}
                                    <span class="badge-pure bg-success">{{ tarefa[6] }}</span>
                                {% else %}
                                    <span class="text-vazio">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if tarefa[9] %}
                                    <span class="badge-pure tag-categoria" style="background-color: {{ tarefa[10] }}; color: white; border: none;">
                                        {{ tarefa[9] }}
                                    </span>
                                {% else %}
                                    <span class="text-vazio">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if tarefa[8] %}
                                    {% set prio_class = 'bg-danger' if tarefa[8] == 'alta' else 'bg-warning text-dark' if tarefa[8] == 'media' else 'bg-success' %}
                                    <span class="badge-pure {{ prio_class }}">{{ tarefa[8]|title }}</span>
                                {% else %}
                                    <span class="text-vazio">-</span>
                                {% endif %}
                            </td>

                            <!-- ACÕES -->
                            <td class="td-acoes">
                                <button type="button" class="btn-acao view" title="Ver detalhes" onclick="verDetalhes({{ tarefa[0] }})">
                                    <i class="bi bi-eye"></i>
                                </button>

                                <a href="{{ url_for('auditoria.historico_tarefa', 
                                                    tarefa_seq=tarefa[0],
                                                    mostrar_inativas=request.args.get('mostrar_inativas', '0'),
                                                    data_inicio=request.args.get('data_inicio'),
                                                    data_fim=request.args.get('data_fim'),
                                                    tipo_data=request.args.get('tipo_data', 'inicio')) }}" 
                                   class="btn-acao audit" 
                                   title="Ver histórico de alterações">
                                    <i class="bi bi-clock-history"></i>
                                </a>

                                {% if tarefa[3] != 'concluido' and tarefa[11] == 1 %}
                                    

                                    <!-- BOTÃO CONCLUIR TAREFAS -->
                                    <button 
                                        type="button"
                                        class="btn-acao check btn-concluir"
                                        data-url="{{ url_for('tarefas.concluir_tarefa', tarefa_seq=tarefa[0]) }}">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    
                                    
                                    <a href="{{ url_for('editar_tarefa.iniedittarefa', tarefa_seq=tarefa[0]) }}" class="btn-acao edit" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    
                                    <!-- BOTAO INATIVAR / EXCLUIR -->
                                    <button 
                                        type="button"
                                        class="btn-acao delete btn-excluir"
                                        data-id="{{ tarefa[0] }}"
                                        data-desc="{{ tarefa[1] }}">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-center py-4 text-white-50">Nenhuma tarefa cadastrada ou nesse período</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

    <!-- HTML MODAL - CONCLUIR TAREFA / DETALHES AUDITORIA / EXCLUIR TAREFA -->
    {% include 'pasta_tarefas/modais/concluir_tarefa.html' %}
    {% include 'pasta_tarefas/modais/detalhes_completo.html' %}
    {% include 'pasta_tarefas/modais/excluir_tarefa.html' %}
    <!-- CSS NO TOPO -->

    <!-- JS MODAL - CONCLUIR TAREFA / DETALHES COMPLETO -->
    <!-- JS MODAL - CONCLUIR TAREFA / DETALHES COMPLETO -->
    {% block scripts %}
        <script src="{{ static_v('js/pasta_tarefas/modais/pasta_excluir/modal_excluir_global.js') }}"></script>
        <script src="{{ static_v('js/pasta_tarefas/modais/concluir_tarefas.js') }}"></script>
        <script src="{{ static_v('js/pasta_tarefas/modais/detalhes_completo.js') }}"></script>
        <script src="{{ static_v('js/pasta_tarefas/modais/pasta_excluir/btn_excluir.js') }}"></script>
    {% endblock %}



{% endblock %}